<mujoco model="Market">

    <compiler autolimits="true" angle="radian"/>
    <option cone="elliptic" impratio="100" timestep="0.002" noslip_iterations="3" integrator="implicitfast"/>

    <size njmax='1000' nconmax='1000'/>
    
    <asset>
        <texture name="texplane" type="2d" height="1" width="1" file="furniture_sim/objects/textures/white_marble_tile2.png"/>
        <material name='MatPlane' shininess="1" texture="texplane" texrepeat="4 4" texuniform="true"/>
        <material name="robotiq_black" shininess="0.9" specular="0.9" reflectance="0.7" rgba="0.1 0.1 0.1 1" />

        <material name="robotiq_chrome" 
                shininess="0.95" 
                specular="1.0" 
                reflectance="0.9"
                rgba="0.8 0.8 0.85 1"/>
    </asset>

    <include file="furniture_sim/objects/trashbin_asset.xml"/>

    <default>
        <default class="visual">
            <geom group="2" type="mesh" contype="0" conaffinity="0"/>
        </default>
        <default class="collision">
            <geom group="3" type="mesh"/>
        </default>
        <default class="primitive_collision">
            <geom group="3" condim="6" solmix="3"/>
        </default>
        <default class="pad_box1">
            <geom mass="0" type="box" friction="15 15 15"  solimp="0.9 0.95 0.001 0.5 2" solref="0.0001 1" solmix="3" priority="1" condim="6" rgba="1 0 0 0"/>
        </default>
        <default class="pad_box2">
            <geom mass="0" type="box" friction="15 15 15" solimp="0.9 0.95 0.001 0.5 2" solref="0.0001 1" solmix="3" priority="1" condim="6" rgba="1 0 0 0"/>
        </default>
    </default>

    <visual>
        <quality shadowsize="0"/>
        <global offwidth="1024" offheight="640"/>
    </visual>

    <worldbody>
        <light name="main_light" pos="0 0 20" dir="0 0 -1" 
            diffuse="0.8 0.8 0.8" specular="1.0 1.0 1.0"/>

        <geom name='floor' pos='0 0 0' size='4 4 0.067' conaffinity='1' contype='1' type='plane' material="MatPlane" condim='3'/>
        <site name='xaxis' pos='0.333 0 0' size='0.0033 0.333' type='capsule' rgba='1 0 0 .25' euler='0 1.57 0' group='3'/>
        <site name='yaxis' pos='0 0.333 0' size='0.0033 0.333' type='capsule' rgba='0 1 0 .25' euler='1.57 0 0' group='3'/>

        <body name="bin" pos="1 -1 0.01" euler="1.57 0 0">
            <freejoint/>
            <include file="furniture_sim/objects/chains/trashbin_chain.xml"/>
        </body>

        <body name="target" pos="1 0 0.1" euler="0 0 0">
            <joint type="free"/>

            <geom
                type="box"
                size="0.05 0.05 0.05"
                rgba="1 0 0 1"
                contype="0"
                conaffinity="0"/>
        </body>


        <camera name="top_view" pos="-8.379 5.744 8.053" xyaxes="-0.562 -0.827 0.000 0.507 -0.344 0.790"/>
    
    </worldbody>
</mujoco>